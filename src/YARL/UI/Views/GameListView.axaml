<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:YARL.UI.ViewModels"
             xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:conv="clr-namespace:YARL.UI.Converters"
             x:Class="YARL.UI.Views.GameListView"
             x:DataType="vm:LibraryViewModel">

    <UserControl.Resources>
        <conv:BoolToOpacityConverter x:Key="BoolToOpacity" />
        <conv:GameStatusToVisibilityConverter x:Key="StatusToVisibility" />
        <conv:BoolToHeartColorConverter x:Key="HeartColor" />
    </UserControl.Resources>

    <DockPanel>
        <!-- Header bar -->
        <Border DockPanel.Dock="Top"
                Background="#1a1a2e"
                Padding="16,8">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto">

                <!-- Back button -->
                <Button Grid.Column="0"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="#FFFFFF"
                        Click="OnBackClicked"
                        ToolTip.Tip="Back to platforms">
                    <mi:MaterialIcon Kind="ChevronLeft"
                                     Width="20" Height="20"
                                     Foreground="#FFFFFF" />
                </Button>

                <!-- Platform / mode name -->
                <TextBlock Grid.Column="1"
                           Text="{Binding GameListTitle}"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="#FFFFFF"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0" />

                <!-- Game count -->
                <TextBlock Grid.Column="2"
                           Text="{Binding FilteredGames.Count, StringFormat=' — {0} games'}"
                           FontSize="12"
                           Foreground="#8888aa"
                           VerticalAlignment="Center"
                           Margin="4,0,0,0" />

                <!-- Favorites filter toggle (two-way bound so it reflects VM state) -->
                <ToggleButton Grid.Column="3"
                              x:Name="FavoritesToggle"
                              Background="Transparent"
                              BorderThickness="0"
                              IsChecked="{Binding ShowFavoritesOnly, Mode=TwoWay}"
                              ToolTip.Tip="Show favorites only">
                    <mi:MaterialIcon Kind="Heart"
                                     Width="20" Height="20"
                                     Foreground="#8888aa" />
                </ToggleButton>

                <!-- Grid / list view toggle (single button cycles between modes) -->
                <ToggleButton Grid.Column="4"
                              Background="Transparent"
                              BorderThickness="0"
                              IsChecked="{Binding IsGridView, Mode=TwoWay}"
                              ToolTip.Tip="{Binding IsGridView, StringFormat={}{0:Switch to list;Switch to grid}}">
                    <Panel>
                        <mi:MaterialIcon Kind="ViewGrid"
                                         Width="20" Height="20"
                                         Foreground="#FFFFFF"
                                         IsVisible="{Binding IsGridView}" />
                        <mi:MaterialIcon Kind="FormatListBulleted"
                                         Width="20" Height="20"
                                         Foreground="#FFFFFF"
                                         IsVisible="{Binding !IsGridView}" />
                    </Panel>
                </ToggleButton>
            </Grid>
        </Border>

        <!-- Content area -->
        <ScrollViewer>
            <Grid>
                <!-- Grid mode -->
                <ItemsControl x:Name="GridRepeater"
                              ItemsSource="{Binding FilteredGames}"
                              Margin="16,16,16,16"
                              IsVisible="{Binding IsGridView}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"
                                       ItemWidth="136"
                                       ItemHeight="176" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:GameViewModel">
                            <Border Width="120" Height="160"
                                    CornerRadius="6"
                                    Background="#16213e"
                                    ClipToBounds="True">
                                <Grid>
                                    <StackPanel>
                                        <!-- Art placeholder -->
                                        <Border Width="120" Height="100"
                                                Background="#0f3460" />

                                        <!-- Title -->
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="12"
                                                   Foreground="#FFFFFF"
                                                   TextWrapping="Wrap"
                                                   MaxLines="2"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="6,4,6,2" />

                                        <!-- Platform badge -->
                                        <TextBlock Text="{Binding PlatformId}"
                                                   FontSize="12"
                                                   Foreground="#8888aa"
                                                   Margin="6,0,6,4" />
                                    </StackPanel>

                                    <!-- Favorite heart button (top-left overlay) -->
                                    <Button Width="28" Height="28"
                                            Padding="0"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Top"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center"
                                            Margin="2,2,0,0"
                                            Tag="{Binding}"
                                            Click="OnFavoriteClicked">
                                        <mi:MaterialIcon Kind="Heart"
                                                         Width="16" Height="16"
                                                         Foreground="{Binding IsFavorite, Converter={StaticResource HeartColor}}" />
                                    </Button>

                                    <!-- Missing warning icon (top-right overlay) -->
                                    <mi:MaterialIcon Kind="Warning"
                                                     Width="16" Height="16"
                                                     Foreground="#E05A5A"
                                                     HorizontalAlignment="Right"
                                                     VerticalAlignment="Top"
                                                     Margin="0,4,4,0"
                                                     IsVisible="{Binding Status, Converter={StaticResource StatusToVisibility}}"
                                                     ToolTip.Tip="File not found — reconnect your ROM source to restore" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Favorites filter empty state -->
                <StackPanel IsVisible="{Binding FavoritesFilterEmptyVisible}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="8"
                            Margin="0,64,0,0">
                    <mi:MaterialIcon Kind="HeartOff"
                                     Width="48" Height="48"
                                     Foreground="#8888aa"
                                     HorizontalAlignment="Center" />
                    <TextBlock Text="No favorites here yet."
                               FontSize="16"
                               Foreground="#8888aa"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Click ♥ to show all games"
                               FontSize="13"
                               Foreground="#555577"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <!-- List mode -->
                <ItemsControl x:Name="ListRepeater"
                              ItemsSource="{Binding FilteredGames}"
                              Margin="0"
                              IsVisible="{Binding !IsGridView}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:GameViewModel">
                            <Border Height="56"
                                    Background="Transparent"
                                    Padding="16,8">
                                <Border.Styles>
                                    <Style Selector="Border:pointerover">
                                        <Setter Property="Background" Value="#0f3460" />
                                    </Style>
                                </Border.Styles>
                                <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                                    <!-- Thumbnail placeholder -->
                                    <Border Grid.Column="0"
                                            Width="40" Height="40"
                                            CornerRadius="4"
                                            Background="#0f3460"
                                            VerticalAlignment="Center" />

                                    <!-- Game title -->
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Title}"
                                               FontSize="16"
                                               Foreground="#FFFFFF"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="12,0,8,0" />

                                    <!-- Platform badge -->
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding PlatformId}"
                                               FontSize="12"
                                               Foreground="#8888aa"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0" />

                                    <!-- Favorite heart button -->
                                    <Button Grid.Column="3"
                                            Width="32" Height="32"
                                            Padding="0"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            VerticalAlignment="Center"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center"
                                            Tag="{Binding}"
                                            Click="OnFavoriteClicked">
                                        <mi:MaterialIcon Kind="Heart"
                                                         Width="20" Height="20"
                                                         Foreground="{Binding IsFavorite, Converter={StaticResource HeartColor}}" />
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </ScrollViewer>
    </DockPanel>
</UserControl>
