<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:YARL.UI.ViewModels"
             xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:conv="clr-namespace:YARL.UI.Converters"
             xmlns:ir="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.ItemsRepeater"
             xmlns:irLayout="clr-namespace:Avalonia.Layout;assembly=Avalonia.Controls.ItemsRepeater"
             xmlns:asyncLoader="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
             x:Class="YARL.UI.Views.GameListView"
             x:DataType="vm:LibraryViewModel">

    <UserControl.Resources>
        <conv:BoolToOpacityConverter x:Key="BoolToOpacity" />
        <conv:GameStatusToVisibilityConverter x:Key="StatusToVisibility" />
        <conv:BoolToHeartColorConverter x:Key="HeartColor" />
        <conv:NullToPlaceholderConverter x:Key="NullToPlaceholder" />
        <conv:ScrapeStatusToVisibilityConverter x:Key="ScrapeStatusToVisibility" />
    </UserControl.Resources>

    <DockPanel>
        <!-- Row 1: Header bar (Back, Title, Count, FavToggle, GridToggle) -->
        <Border DockPanel.Dock="Top"
                Background="#1a1a2e"
                Padding="16,8">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto">

                <!-- Back button -->
                <Button Grid.Column="0"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="#FFFFFF"
                        Click="OnBackClicked"
                        ToolTip.Tip="Back to platforms">
                    <mi:MaterialIcon Kind="ChevronLeft"
                                     Width="20" Height="20"
                                     Foreground="#FFFFFF" />
                </Button>

                <!-- Platform / mode name -->
                <TextBlock Grid.Column="1"
                           Text="{Binding GameListTitle}"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="#FFFFFF"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0" />

                <!-- Game count -->
                <TextBlock Grid.Column="2"
                           Text="{Binding FilteredGames.Count, StringFormat=' — {0} games'}"
                           FontSize="12"
                           Foreground="#8888aa"
                           VerticalAlignment="Center"
                           Margin="4,0,0,0" />

                <!-- Favorites filter toggle -->
                <ToggleButton Grid.Column="3"
                              x:Name="FavoritesToggle"
                              Background="Transparent"
                              BorderThickness="0"
                              IsChecked="{Binding ShowFavoritesOnly, Mode=TwoWay}"
                              ToolTip.Tip="Show favorites only">
                    <mi:MaterialIcon Kind="Heart"
                                     Width="20" Height="20"
                                     Foreground="#8888aa" />
                </ToggleButton>

                <!-- Grid / list view toggle -->
                <ToggleButton Grid.Column="4"
                              Background="Transparent"
                              BorderThickness="0"
                              IsChecked="{Binding IsGridView, Mode=TwoWay}"
                              ToolTip.Tip="{Binding IsGridView, StringFormat={}{0:Switch to list;Switch to grid}}">
                    <Panel>
                        <mi:MaterialIcon Kind="ViewGrid"
                                         Width="20" Height="20"
                                         Foreground="#FFFFFF"
                                         IsVisible="{Binding IsGridView}" />
                        <mi:MaterialIcon Kind="FormatListBulleted"
                                         Width="20" Height="20"
                                         Foreground="#FFFFFF"
                                         IsVisible="{Binding !IsGridView}" />
                    </Panel>
                </ToggleButton>
            </Grid>
        </Border>

        <!-- Row 2: Search bar -->
        <Border DockPanel.Dock="Top" Background="#1a1a2e" Padding="16,8,16,4">
            <TextBox Text="{Binding SearchText, Mode=TwoWay}"
                     Watermark="Search..."
                     FontSize="14"
                     Background="#16213e"
                     BorderBrush="#0f3460"
                     CornerRadius="4"
                     Height="36"
                     AutomationProperties.Name="Search games" />
        </Border>

        <!-- Row 3: Search status + filter chips -->
        <Border DockPanel.Dock="Top" Background="#1a1a2e" Padding="16,4,16,4">
            <StackPanel Spacing="4">
                <!-- Search status (visible only when searching) -->
                <StackPanel Orientation="Horizontal"
                            IsVisible="{Binding SearchText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    <TextBlock FontSize="12" Foreground="#8888aa" VerticalAlignment="Center">
                        <Run Text="{Binding FilteredGames.Count}" />
                        <Run Text=" matches in " />
                        <Run Text="{Binding GameListTitle}" />
                        <Run Text=" / " />
                        <Run Text="{Binding SearchGlobalMatchCount}" />
                        <Run Text=" total globally" />
                    </TextBlock>
                    <Button Content="search globally"
                            FontSize="12"
                            Foreground="#7C6FF7"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="4,0"
                            Cursor="Hand"
                            Click="OnSearchGloballyClicked" />
                </StackPanel>

                <!-- Filter chip row -->
                <WrapPanel Orientation="Horizontal" Margin="0,2,0,0">
                    <!-- Genre chip -->
                    <Border CornerRadius="16" Padding="8,4" Margin="0,0,8,0" Height="28"
                            Background="#16213e"
                            BorderBrush="#0f3460" BorderThickness="1">
                        <ComboBox ItemsSource="{Binding AvailableGenres}"
                                  SelectedItem="{Binding ActiveGenreFilter, Mode=TwoWay}"
                                  PlaceholderText="Genre"
                                  FontSize="12"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Padding="0" />
                    </Border>

                    <!-- Developer chip -->
                    <Border CornerRadius="16" Padding="8,4" Margin="0,0,8,0" Height="28"
                            Background="#16213e"
                            BorderBrush="#0f3460" BorderThickness="1">
                        <ComboBox ItemsSource="{Binding AvailableDevelopers}"
                                  SelectedItem="{Binding ActiveDeveloperFilter, Mode=TwoWay}"
                                  PlaceholderText="Developer"
                                  FontSize="12"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Padding="0" />
                    </Border>

                    <!-- Clear filters button -->
                    <Button Content="Clear filters"
                            FontSize="12"
                            Foreground="#7C6FF7"
                            Background="Transparent"
                            BorderThickness="0"
                            Command="{Binding ClearFiltersCommand}"
                            IsVisible="{Binding ActiveGenreFilter, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- Content area -->
        <ScrollViewer>
            <StackPanel>
                <Grid>
                    <!-- Grid mode: ItemsRepeater + UniformGridLayout for virtualized scrolling -->
                    <ir:ItemsRepeater x:Name="GridRepeater"
                                      ItemsSource="{Binding FilteredGames}"
                                      Margin="16"
                                      IsVisible="{Binding IsGridView}">
                        <ir:ItemsRepeater.Layout>
                            <irLayout:UniformGridLayout MinItemWidth="136"
                                                        MinItemHeight="176"
                                                        MinColumnSpacing="0"
                                                        MinRowSpacing="0" />
                        </ir:ItemsRepeater.Layout>
                        <ir:ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:GameViewModel">
                                <Button Background="Transparent" BorderThickness="0" Padding="4"
                                        Command="{Binding $parent[ir:ItemsRepeater].((vm:LibraryViewModel)DataContext).SelectGameCommand}"
                                        CommandParameter="{Binding}">
                                    <Border Width="120" Height="160" CornerRadius="6"
                                            Background="#16213e" ClipToBounds="True">
                                        <Grid>
                                            <StackPanel>
                                                <!-- Cover art area with platform-themed border -->
                                                <Grid Width="120" Height="100">
                                                    <!-- Placeholder (visible when no cover art) -->
                                                    <Border Background="#0f3460"
                                                            IsVisible="{Binding CoverArtPath, Converter={StaticResource NullToPlaceholder}}" />

                                                    <!-- Cover art via AsyncImageLoader AdvancedImage -->
                                                    <asyncLoader:AdvancedImage
                                                        Source="{Binding CoverArtPath}"
                                                        Width="120" Height="100"
                                                        Stretch="UniformToFill"
                                                        IsVisible="{Binding CoverArtPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                                                    <!-- Platform-themed border (2px) -->
                                                    <Border BorderThickness="2"
                                                            BorderBrush="#0f3460"
                                                            IsHitTestVisible="False" />

                                                    <!-- "No art" badge (bottom-left, only for unmatched) -->
                                                    <Border Background="#0f3460" CornerRadius="8"
                                                            Padding="6,2"
                                                            HorizontalAlignment="Left"
                                                            VerticalAlignment="Bottom"
                                                            Margin="4,0,0,4"
                                                            IsVisible="{Binding ScrapeStatus, Converter={StaticResource ScrapeStatusToVisibility}}">
                                                        <TextBlock Text="No art" FontSize="10" Foreground="#8888aa" />
                                                    </Border>

                                                    <!-- Play button overlay (bottom-right, 44x44px) -->
                                                    <Button Width="44" Height="44"
                                                            CornerRadius="22"
                                                            Background="#99000000"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Bottom"
                                                            Margin="0,0,4,4"
                                                            Padding="0"
                                                            HorizontalContentAlignment="Center"
                                                            VerticalContentAlignment="Center"
                                                            ToolTip.Tip="Launch — emulator not configured yet"
                                                            Classes="playOverlay"
                                                            Opacity="0">
                                                        <Button.Styles>
                                                            <Style Selector="Border:pointerover Button.playOverlay">
                                                                <Setter Property="Opacity" Value="1" />
                                                            </Style>
                                                        </Button.Styles>
                                                        <mi:MaterialIcon Kind="Play" Width="24" Height="24" Foreground="#FFFFFF" />
                                                    </Button>
                                                </Grid>

                                                <!-- Title -->
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="12" Foreground="#FFFFFF"
                                                           TextWrapping="Wrap" MaxLines="2"
                                                           TextTrimming="CharacterEllipsis"
                                                           Margin="6,4,6,2" />

                                                <!-- Platform badge -->
                                                <TextBlock Text="{Binding PlatformId}"
                                                           FontSize="10" Foreground="#8888aa"
                                                           Margin="6,0,6,4" />
                                            </StackPanel>

                                            <!-- Favorite heart (top-left overlay) -->
                                            <Button Width="28" Height="28" Padding="0"
                                                    Background="Transparent" BorderThickness="0"
                                                    HorizontalAlignment="Left" VerticalAlignment="Top"
                                                    HorizontalContentAlignment="Center"
                                                    VerticalContentAlignment="Center"
                                                    Margin="2,2,0,0"
                                                    Tag="{Binding}" Click="OnFavoriteClicked">
                                                <mi:MaterialIcon Kind="Heart" Width="16" Height="16"
                                                                 Foreground="{Binding IsFavorite, Converter={StaticResource HeartColor}}" />
                                            </Button>

                                            <!-- Missing warning (top-right overlay) -->
                                            <mi:MaterialIcon Kind="Warning" Width="16" Height="16"
                                                             Foreground="#E05A5A"
                                                             HorizontalAlignment="Right" VerticalAlignment="Top"
                                                             Margin="0,4,4,0"
                                                             IsVisible="{Binding Status, Converter={StaticResource StatusToVisibility}}"
                                                             ToolTip.Tip="File not found — reconnect your ROM source to restore" />
                                        </Grid>
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </ir:ItemsRepeater.ItemTemplate>
                    </ir:ItemsRepeater>

                    <!-- Favorites filter empty state -->
                    <StackPanel IsVisible="{Binding FavoritesFilterEmptyVisible}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="8"
                                Margin="0,64,0,0">
                        <mi:MaterialIcon Kind="HeartOff"
                                         Width="48" Height="48"
                                         Foreground="#8888aa"
                                         HorizontalAlignment="Center" />
                        <TextBlock Text="No favorites here yet."
                                   FontSize="16"
                                   Foreground="#8888aa"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="Click ♥ to show all games"
                                   FontSize="13"
                                   Foreground="#555577"
                                   HorizontalAlignment="Center" />
                    </StackPanel>

                    <!-- List mode -->
                    <ItemsControl x:Name="ListRepeater"
                                  ItemsSource="{Binding FilteredGames}"
                                  Margin="0"
                                  IsVisible="{Binding !IsGridView}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:GameViewModel">
                                <Border Height="56"
                                        Background="Transparent"
                                        Padding="16,8">
                                    <Border.Styles>
                                        <Style Selector="Border:pointerover">
                                            <Setter Property="Background" Value="#0f3460" />
                                        </Style>
                                    </Border.Styles>
                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                                        <!-- Thumbnail with cover art -->
                                        <Grid Grid.Column="0" Width="40" Height="40">
                                            <Border CornerRadius="4" Background="#0f3460"
                                                    IsVisible="{Binding CoverArtPath, Converter={StaticResource NullToPlaceholder}}" />
                                            <asyncLoader:AdvancedImage Source="{Binding CoverArtPath}"
                                                                        Width="40" Height="40"
                                                                        Stretch="UniformToFill"
                                                                        IsVisible="{Binding CoverArtPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                        </Grid>

                                        <!-- Game title -->
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Title}"
                                                   FontSize="16"
                                                   Foreground="#FFFFFF"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="12,0,8,0" />

                                        <!-- Platform badge -->
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding PlatformId}"
                                                   FontSize="12"
                                                   Foreground="#8888aa"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,0" />

                                        <!-- Favorite heart button -->
                                        <Button Grid.Column="3"
                                                Width="32" Height="32"
                                                Padding="0"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                VerticalAlignment="Center"
                                                HorizontalContentAlignment="Center"
                                                VerticalContentAlignment="Center"
                                                Tag="{Binding}"
                                                Click="OnFavoriteClicked">
                                            <mi:MaterialIcon Kind="Heart"
                                                             Width="20" Height="20"
                                                             Foreground="{Binding IsFavorite, Converter={StaticResource HeartColor}}" />
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>

                <!-- Load more button (LIB-04: 50-result cap with Load more) -->
                <Button Content="Load more"
                        HorizontalAlignment="Center"
                        Margin="0,8,0,16"
                        Padding="24,8"
                        FontSize="14"
                        Foreground="#7C6FF7"
                        Background="Transparent"
                        BorderBrush="#555577"
                        BorderThickness="1"
                        CornerRadius="4"
                        Command="{Binding LoadMoreCommand}"
                        IsVisible="{Binding HasMoreResults}" />
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
