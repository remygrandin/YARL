<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:YARL.UI.ViewModels"
             xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:views="clr-namespace:YARL.UI.Views"
             x:Class="YARL.UI.Views.LibraryView"
             x:DataType="vm:LibraryViewModel"
             Background="#1a1a2e">

    <Grid>
        <!-- Empty state: no platforms and not scanning -->
        <views:EmptyStateView IsVisible="{Binding IsEmptyState}"
                              DataContext="{Binding}" />

        <!-- Scanning state: no platforms but scanning -->
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    IsVisible="{Binding IsScanningEmpty}">
            <mi:MaterialIcon Kind="Sync"
                             Width="40" Height="40"
                             Foreground="#7C6FF7"
                             HorizontalAlignment="Center">
                <mi:MaterialIcon.RenderTransform>
                    <RotateTransform />
                </mi:MaterialIcon.RenderTransform>
                <mi:MaterialIcon.Styles>
                    <Style Selector="mi|MaterialIcon">
                        <Style.Animations>
                            <Animation Duration="0:0:1" IterationCount="Infinite">
                                <KeyFrame Cue="0%">
                                    <Setter Property="RotateTransform.Angle" Value="0" />
                                </KeyFrame>
                                <KeyFrame Cue="100%">
                                    <Setter Property="RotateTransform.Angle" Value="360" />
                                </KeyFrame>
                            </Animation>
                        </Style.Animations>
                    </Style>
                </mi:MaterialIcon.Styles>
            </mi:MaterialIcon>
            <TextBlock Text="Scanning your ROM folders..."
                       FontSize="16"
                       Foreground="#ccccdd"
                       HorizontalAlignment="Center"
                       Margin="0,12,0,0" />
        </StackPanel>

        <!-- Content state: platforms exist -->
        <ScrollViewer IsVisible="{Binding HasPlatforms}"
                      Padding="32,24,32,24">
            <StackPanel Spacing="0">

                <!-- Recently Played carousel -->
                <StackPanel IsVisible="{Binding HasRecentlyPlayed}"
                            Margin="0,0,0,32">
                    <TextBlock Text="Continue Playing"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#FFFFFF"
                               Margin="0,0,0,8" />
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding RecentlyPlayed}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:GameViewModel">
                                    <Border Width="120" Height="160"
                                            CornerRadius="6"
                                            Background="#16213e"
                                            ClipToBounds="True">
                                        <Border.Styles>
                                            <Style Selector="Border:pointerover">
                                                <Setter Property="Background" Value="#0f3460" />
                                            </Style>
                                        </Border.Styles>
                                        <StackPanel>
                                            <Border Width="120" Height="100"
                                                    Background="#0f3460" />
                                            <TextBlock Text="{Binding Title}"
                                                       FontSize="12"
                                                       Foreground="#FFFFFF"
                                                       TextWrapping="Wrap"
                                                       MaxLines="2"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="6,4,6,2" />
                                            <TextBlock Text="{Binding PlatformId}"
                                                       FontSize="12"
                                                       Foreground="#8888aa"
                                                       Margin="6,0,6,4" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>

                <!-- Favorites carousel -->
                <StackPanel IsVisible="{Binding HasFavorites}"
                            Margin="0,0,0,32">
                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,8">
                        <mi:MaterialIcon Kind="Heart"
                                         Width="20" Height="20"
                                         Foreground="#7C6FF7"
                                         VerticalAlignment="Center" />
                        <TextBlock Text="Favorites"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="#FFFFFF"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Favorites}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:GameViewModel">
                                    <Border Width="120" Height="160"
                                            CornerRadius="6"
                                            Background="#16213e"
                                            ClipToBounds="True">
                                        <Border.Styles>
                                            <Style Selector="Border:pointerover">
                                                <Setter Property="Background" Value="#0f3460" />
                                            </Style>
                                        </Border.Styles>
                                        <StackPanel>
                                            <Border Width="120" Height="100"
                                                    Background="#0f3460" />
                                            <TextBlock Text="{Binding Title}"
                                                       FontSize="12"
                                                       Foreground="#FFFFFF"
                                                       TextWrapping="Wrap"
                                                       MaxLines="2"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="6,4,6,2" />
                                            <TextBlock Text="{Binding PlatformId}"
                                                       FontSize="12"
                                                       Foreground="#8888aa"
                                                       Margin="6,0,6,4" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>

                <!-- Platform Grid -->
                <views:PlatformGridView DataContext="{Binding}" />

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
