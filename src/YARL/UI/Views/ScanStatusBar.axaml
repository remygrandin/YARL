<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:YARL.UI.ViewModels"
             xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="YARL.UI.Views.ScanStatusBar"
             x:DataType="vm:LibraryViewModel">

    <UserControl.Styles>
        <Style Selector="Border.status-bar">
            <Setter Property="Background" Value="#16213e" />
            <Setter Property="Height" Value="32" />
        </Style>
    </UserControl.Styles>

    <Border Classes="status-bar"
            IsVisible="{Binding IsScanning}">
        <Grid ColumnDefinitions="Auto,Auto,*,Auto" Margin="8,0">

            <!-- Spinning sync icon (visible when scanning) -->
            <mi:MaterialIcon Grid.Column="0"
                             Kind="Sync"
                             Width="16" Height="16"
                             Foreground="#7C6FF7"
                             VerticalAlignment="Center"
                             IsVisible="{Binding IsScanning}">
                <mi:MaterialIcon.RenderTransform>
                    <RotateTransform />
                </mi:MaterialIcon.RenderTransform>
                <mi:MaterialIcon.Styles>
                    <Style Selector="mi|MaterialIcon">
                        <Style.Animations>
                            <Animation Duration="0:0:1" IterationCount="Infinite">
                                <KeyFrame Cue="0%">
                                    <Setter Property="RotateTransform.Angle" Value="0" />
                                </KeyFrame>
                                <KeyFrame Cue="100%">
                                    <Setter Property="RotateTransform.Angle" Value="360" />
                                </KeyFrame>
                            </Animation>
                        </Style.Animations>
                    </Style>
                </mi:MaterialIcon.Styles>
            </mi:MaterialIcon>

            <!-- Status text -->
            <TextBlock Grid.Column="1"
                       Text="{Binding ScanProgressText}"
                       FontSize="12"
                       Foreground="#ccccdd"
                       VerticalAlignment="Center"
                       Margin="8,0,0,0" />

            <!-- Spacer -->
            <Grid Grid.Column="2" />

            <!-- Cancel button -->
            <Button Grid.Column="3"
                    Content="Cancel"
                    FontSize="12"
                    Foreground="#8888aa"
                    Background="Transparent"
                    BorderThickness="0"
                    VerticalAlignment="Center"
                    IsVisible="{Binding IsScanning}"
                    Command="{Binding CancelScanCommand}"
                    Margin="0,0,8,0" />
        </Grid>
    </Border>
</UserControl>
